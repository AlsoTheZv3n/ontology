# Database
DATABASE_URL=postgresql://ontology:ontology@postgres:5432/ontology

# Redis
REDIS_URL=redis://redis:6379

# GitHub (optional — increases rate limit from 60 to 5000 req/h)
# Create at: github.com/settings/tokens → Classic → Scope: public_repo
GITHUB_TOKEN=

# SEC EDGAR (required User-Agent header)
SEC_USER_AGENT=YourName your@email.com

# Anthropic API (Agent Chat — required for /chat)
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=

# Alpha Vantage (Market data — market cap, PE, revenue, sector)
# Get at: alphavantage.co/support/#api-key (free, instant)
ALPHA_VANTAGE_KEY=

# FRED (Federal Reserve Economic Data — interest rates, GDP, inflation)
# Get at: fredaccount.stlouisfed.org (free, instant)
FRED_API_KEY=

# EIA (Energy Information Admin — oil, gas, electricity prices)
# Get at: eia.gov/opendata/register.php (free, via email)
EIA_API_KEY=

# Cloudflare R2 (optional — raw blob storage)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=ontology-raw
